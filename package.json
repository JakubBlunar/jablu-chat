{
  "name": "chat",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo dev --filter=!@chat/bot",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "db:migrate:dev": "pnpm --filter @chat/server db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @chat/server db:migrate:deploy",
    "db:generate": "pnpm --filter @chat/server db:generate",
    "db:studio": "pnpm --filter @chat/server db:studio",
    "desktop": "pnpm --filter @chat/desktop start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup": "bash setup.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "~5.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "esbuild",
      "@swc/core",
      "electron",
      "electron-winstaller",
      "better-sqlite3"
    ]
  }
}
