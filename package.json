{
  "name": "chat",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "db:migrate:dev": "pnpm --filter @chat/server db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @chat/server db:migrate:deploy",
    "db:generate": "pnpm --filter @chat/server db:generate",
    "db:studio": "pnpm --filter @chat/server db:studio",
    "setup": "bash setup.sh"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "~5.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "esbuild",
      "@swc/core"
    ]
  }
}
