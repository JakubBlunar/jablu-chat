# =============================================================================
# Chat App - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values.
# Run ./setup.sh to auto-generate secrets.
# =============================================================================

# Server host: use IP for now, swap to a domain later
SERVER_HOST=192.168.1.100

# TLS mode: "off" (HTTP only), "self-signed" (self-signed cert), "letsencrypt" (auto cert via domain)
TLS_MODE=off

# API port (internal, behind Nginx)
PORT=3001

# PostgreSQL
POSTGRES_USER=chat
POSTGRES_PASSWORD=changeme
POSTGRES_DB=chat
# Full Docker stack (`docker compose up`): use service hostnames postgres / redis.
DATABASE_URL=postgresql://chat:changeme@postgres:5432/chat

# Hybrid local dev (`docker compose -f docker-compose.dev.yml up -d` + `pnpm dev` on the host):
# the API cannot reach hostname "postgres". Copy `.env.development.example` → `.env.development`
# (gitignored) so DATABASE_URL / REDIS_URL use 127.0.0.1 — loaded after `.env` by Nest and Prisma CLI.

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=changeme-jwt-secret
JWT_REFRESH_SECRET=changeme-jwt-refresh-secret

# LiveKit
LIVEKIT_API_KEY=changeme-livekit-key
LIVEKIT_API_SECRET=changeme-livekit-secret
LIVEKIT_URL=ws://localhost/livekit

# Registration mode: "open" (anyone can register) or "invite" (invite code required)
REGISTRATION_MODE=open

# Superadmin (credentials for /admin panel)
SUPERADMIN_USERNAME=changeme-admin-username
SUPERADMIN_PASSWORD=changeme-admin-password

# File Storage (local filesystem)
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_SIZE_MB=50

# Desktop App Updates (directory for electron-updater artifacts)
UPDATES_DIR=/data/updates

# Desktop App Downloads (installer files served to users)
DOWNLOADS_DIR=/data/downloads

# Storage Cleanup
STORAGE_LIMIT_GB=100
CLEANUP_ENABLED=false
CLEANUP_CRON=0 3 * * *
CLEANUP_MIN_AGE_DAYS=90
CLEANUP_DELETE_MESSAGES=false
CLEANUP_ORPHAN_HOURS=24
CLEANUP_SKIP_ARCHIVED=true

# Web Push (VAPID) - run: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# In-app notification center (max persisted rows per user; TTL 0 = disabled)
IN_APP_NOTIFICATION_CAP=500
IN_APP_NOTIFICATION_TTL_DAYS=0

# Email (SMTP)
# In dev: leave defaults (points to Mailpit container on port 1025)
# In prod: set to real SMTP (Gmail, Mailgun, etc.)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@chat.local

# Log watcher (optional Docker profile `log-watcher`)
# docker compose --profile log-watcher up -d
# LOG_WATCHER_ALERT_TO=you@example.com
# LOG_WATCHER_SERVICES=api,nginx
# LOG_WATCHER_POLL_MS=120000
# LOG_WATCHER_LOG_SINCE=3m
# LOG_WATCHER_PATTERNS=ERROR [,WARN [,Exception,Unhandled,FATAL
# LOG_WATCHER_MAX_EMAILS_PER_HOUR=5
# LOG_WATCHER_DRY_RUN=0
# COMPOSE_PROJECT_NAME=chat

# Giphy API (optional - enables GIF picker)
# Get a free key at https://developers.giphy.com/dashboard
GIPHY_API_KEY=
