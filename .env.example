# =============================================================================
# Chat App - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values.
# Run ./setup.sh to auto-generate secrets.
# =============================================================================

# Server host: use IP for now, swap to a domain later (e.g. chat.example.com)
SERVER_HOST=192.168.1.100

# TLS mode: "off" (HTTP only), "self-signed" (self-signed cert), "letsencrypt" (auto cert via domain)
TLS_MODE=off

# API port (internal, behind Nginx)
PORT=3001

# PostgreSQL
POSTGRES_USER=chat
POSTGRES_PASSWORD=changeme
POSTGRES_DB=chat
DATABASE_URL=postgresql://chat:changeme@postgres:5432/chat

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=changeme-jwt-secret
JWT_REFRESH_SECRET=changeme-jwt-refresh-secret

# LiveKit
LIVEKIT_API_KEY=changeme-livekit-key
LIVEKIT_API_SECRET=changeme-livekit-secret
LIVEKIT_URL=ws://localhost/livekit

# Registration mode: "open" (anyone can register) or "invite" (invite code required)
REGISTRATION_MODE=open

# Superadmin (password for /admin panel)
SUPERADMIN_PASSWORD=changeme-admin-password

# File Storage (local filesystem)
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_SIZE_MB=50

# Desktop App Updates (directory for electron-updater artifacts)
UPDATES_DIR=/data/updates

# Desktop App Downloads (installer files served to users)
DOWNLOADS_DIR=/data/downloads

# Storage Cleanup
STORAGE_LIMIT_GB=100
CLEANUP_ENABLED=false
CLEANUP_CRON=0 3 * * *
CLEANUP_MIN_AGE_DAYS=30
CLEANUP_DELETE_MESSAGES=false
CLEANUP_ORPHAN_HOURS=24

# Email (SMTP)
# In dev: leave defaults (points to Mailpit container on port 1025)
# In prod: set to real SMTP (Gmail, Mailgun, etc.)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@chat.local
