# =============================================================================
# Chat App - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values.
# Run ./setup.sh to auto-generate secrets.
# =============================================================================

# Server host: use IP for now, swap to a domain later (e.g. chat.example.com)
SERVER_HOST=192.168.1.100

# TLS mode: "off" (HTTP only), "self-signed" (self-signed cert), "letsencrypt" (auto cert via domain)
TLS_MODE=off

# API port (internal, behind Nginx)
PORT=3001

# PostgreSQL
POSTGRES_USER=chat
POSTGRES_PASSWORD=changeme
POSTGRES_DB=chat
DATABASE_URL=postgresql://chat:changeme@postgres:5432/chat

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=changeme-jwt-secret
JWT_REFRESH_SECRET=changeme-jwt-refresh-secret

# LiveKit
LIVEKIT_API_KEY=changeme-livekit-key
LIVEKIT_API_SECRET=changeme-livekit-secret
LIVEKIT_URL=ws://localhost/livekit

# File Storage (local filesystem)
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_SIZE_MB=50

# Email (SMTP)
# In dev: leave defaults (points to Mailpit container on port 1025)
# In prod: set to real SMTP (Gmail, Mailgun, etc.)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@chat.local
