{
  "name": "@chat/desktop",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "start": "tsc -p tsconfig.json && electron dist/main/index.js",
    "build": "tsc -p tsconfig.json",
    "pack": "electron-builder --dir",
    "predist": "tsc -p tsconfig.json",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^26.0.12",
    "typescript": "~5.9.3"
  },
  "build": {
    "appId": "com.jablu.desktop",
    "productName": "Jablu",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "*.png",
          "*.ico"
        ]
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "https://your-server.example.com/api/updates"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon-512.png"
    },
    "nsis": {
      "allowToChangeInstallationDirectory": false,
      "oneClick": true
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon-512.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon-512.png"
    }
  }
}
