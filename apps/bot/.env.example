# Bot token (generated when creating bot in Jablu web UI)
BOT_TOKEN=bot_your_token_here

# Server URL (Jablu API server)
SERVER_URL=http://localhost:3001

# How often to poll for new deals (cron expression, default: every hour)
POLL_CRON=0 * * * *

# Path to SQLite database file
DB_PATH=./data/bot.db
