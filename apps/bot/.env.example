# Comma-separated list of Jablu webhook execute URLs
# Each URL corresponds to a server/channel the bot will post to
# Example: https://chat.example.com/api/webhooks/<token>/execute
WEBHOOK_URLS=http://localhost:3000/api/webhooks/<token1>/execute,http://localhost:3000/api/webhooks/<token2>/execute

# Bot display name (shown in chat)
BOT_NAME=FreeGameBot

# Bot avatar URL (optional, shown in chat)
BOT_AVATAR_URL=

# How often to poll for new deals (cron expression, default: every hour)
POLL_CRON=0 * * * *

# Path to SQLite database file
DB_PATH=./data/bot.db
