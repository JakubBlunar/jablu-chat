# Copy these lines into the repo root `.env` (same file as SMTP_* for the API).
# Do not commit real secrets.

# Required unless testing:
# LOG_WATCHER_ALERT_TO=ops@example.com

# Optional dry run (logs matches to stdout, no email):
# LOG_WATCHER_DRY_RUN=1

# Must match `docker compose ls` project name for this stack (often the folder name):
# COMPOSE_PROJECT_NAME=chat

# LOG_WATCHER_SERVICES=api,nginx
# LOG_WATCHER_POLL_MS=120000
# LOG_WATCHER_LOG_SINCE=3m
# LOG_WATCHER_PATTERNS=ERROR [,WARN [,Exception,Unhandled,FATAL
# LOG_WATCHER_MAX_EMAILS_PER_HOUR=5
# LOG_WATCHER_START_DELAY_MS=30000

# Same SMTP as the API (Mailpit in dev, real relay in prod):
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@chat.local
