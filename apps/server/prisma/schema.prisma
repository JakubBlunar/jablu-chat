generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  bio          String?
  status       UserStatus @default(offline)
  customStatus String?    @map("custom_status")
  dmPrivacy    DmPrivacy  @default(everyone) @map("dm_privacy")
  lastSeenAt   DateTime?  @map("last_seen_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  messages          Message[]
  serverMemberships ServerMember[]
  passwordResets    PasswordReset[]
  reactions         Reaction[]
  invitesCreated    Invite[]
  webhooksCreated   Webhook[]
  customEmojis      CustomEmoji[]          @relation("UploadedEmojis")
  ownedServers      Server[]               @relation("ServerOwner")
  dmMemberships     DirectConversationMember[]
  refreshTokens     RefreshToken[]
  pushSubscriptions PushSubscription[]
  auditLogs         AuditLog[]             @relation("auditLogActor")
  usedInvites       RegistrationInvite[]   @relation("UsedInvites")
  createdEvents     ServerEvent[]          @relation("EventCreator")
  eventInterests    EventInterest[]
  pollVotes         PollVote[]
  friendRequestsSent     Friendship[]     @relation("FriendRequestsSent")
  friendRequestsReceived Friendship[]     @relation("FriendRequestsReceived")
  bookmarks              MessageBookmark[]
  bans                   ServerBan[]      @relation("BannedUser")
  bansIssued             ServerBan[]      @relation("BanActor")

  @@map("users")
}

enum UserStatus {
  online
  idle
  dnd
  offline
}

enum DmPrivacy {
  everyone
  friends_only
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model Server {
  id          String   @id @default(uuid())
  name        String
  iconUrl     String?  @map("icon_url")
  ownerId     String   @map("owner_id")
  vanityCode  String?  @unique @map("vanity_code")
  welcomeChannelId String? @map("welcome_channel_id")
  welcomeMessage   String? @map("welcome_message")
  afkChannelId     String? @map("afk_channel_id")
  afkTimeout       Int     @default(300) @map("afk_timeout")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner               User                 @relation("ServerOwner", fields: [ownerId], references: [id])
  channels            Channel[]
  categories          ChannelCategory[]
  members             ServerMember[]
  roles               Role[]
  invites             Invite[]
  customEmojis        CustomEmoji[]
  auditLogs           AuditLog[]
  registrationInvites RegistrationInvite[]
  events              ServerEvent[]
  autoModRules        AutoModRule[]
  bans                ServerBan[]
  welcomeChannel      Channel?             @relation("WelcomeChannel", fields: [welcomeChannelId], references: [id], onDelete: SetNull)
  afkChannel          Channel?             @relation("AfkChannel", fields: [afkChannelId], references: [id], onDelete: SetNull)

  @@map("servers")
}

model ServerMember {
  userId     String      @map("user_id")
  serverId   String      @map("server_id")
  roleId     String      @map("role_id")
  notifLevel NotifLevel? @map("notif_level")
  mutedUntil DateTime?   @map("muted_until")
  joinedAt   DateTime    @default(now()) @map("joined_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, serverId])
  @@index([serverId])
  @@index([roleId])
  @@map("server_members")
}

model ServerBan {
  id        String   @id @default(uuid())
  serverId  String   @map("server_id")
  userId    String   @map("user_id")
  bannedBy  String   @map("banned_by")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User   @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  actor  User   @relation("BanActor", fields: [bannedBy], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
  @@index([serverId])
  @@map("server_bans")
}

model Role {
  id          String   @id @default(uuid())
  serverId    String   @map("server_id")
  name        String
  color       String?
  position    Int      @default(0)
  permissions BigInt   @default(0)
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")

  server           Server                    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members          ServerMember[]
  channelOverrides ChannelPermissionOverride[]

  @@unique([serverId, name])
  @@map("server_roles")
}

model ChannelPermissionOverride {
  id        String @id @default(uuid())
  channelId String @map("channel_id")
  roleId    String @map("role_id")
  allow     BigInt @default(0)
  deny      BigInt @default(0)

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([channelId, roleId])
  @@map("channel_permission_overrides")
}

model ChannelCategory {
  id        String   @id @default(uuid())
  serverId  String   @map("server_id")
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  server   Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channels Channel[]

  @@map("channel_categories")
}

model Channel {
  id         String      @id @default(uuid())
  serverId   String      @map("server_id")
  categoryId String?     @map("category_id")
  name       String
  type       ChannelType @default(text)
  position   Int         @default(0)
  isArchived Boolean     @default(false) @map("is_archived")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  server              Server                    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  category            ChannelCategory?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  messages            Message[]
  webhooks            Webhook[]
  notifPreferences    ChannelNotifPref[]
  readStates          ChannelReadState[]
  events              ServerEvent[]
  permissionOverrides ChannelPermissionOverride[]
  welcomeForServers   Server[]                  @relation("WelcomeChannel")
  afkForServers       Server[]                  @relation("AfkChannel")

  @@unique([serverId, name])
  @@map("channels")
}

enum ChannelType {
  text
  voice
}

model DirectConversation {
  id        String   @id @default(uuid())
  isGroup   Boolean  @default(false) @map("is_group")
  groupName String?  @map("group_name")
  createdAt DateTime @default(now()) @map("created_at")

  members    DirectConversationMember[]
  messages   Message[]
  readStates DmReadState[]

  @@map("direct_conversations")
}

model DirectConversationMember {
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  joinedAt       DateTime  @default(now()) @map("joined_at")
  closedAt       DateTime? @map("closed_at")

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
  @@map("direct_conversation_members")
}

model Message {
  id                     String   @id @default(uuid())
  channelId              String?  @map("channel_id")
  directConversationId   String?  @map("direct_conversation_id")
  authorId               String?  @map("author_id")
  replyToId              String?  @map("reply_to_id")
  threadParentId         String?  @map("thread_parent_id")
  content                String?
  pinned                 Boolean  @default(false)
  deleted                Boolean  @default(false)
  webhookId              String?  @map("webhook_id")
  webhookName            String?  @map("webhook_name")
  webhookAvatarUrl       String?  @map("webhook_avatar_url")
  createdAt              DateTime @default(now()) @map("created_at")
  editedAt               DateTime? @map("edited_at")

  author             User?               @relation(fields: [authorId], references: [id], onDelete: SetNull)
  channel            Channel?            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  directConversation DirectConversation? @relation(fields: [directConversationId], references: [id], onDelete: Cascade)
  replyTo            Message?            @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies            Message[]           @relation("MessageReplies")
  threadParent       Message?            @relation("MessageThreads", fields: [threadParentId], references: [id], onDelete: SetNull)
  threadMessages     Message[]           @relation("MessageThreads")
  webhook            Webhook?            @relation(fields: [webhookId], references: [id], onDelete: SetNull)
  attachments        Attachment[]
  reactions          Reaction[]
  linkPreviews       LinkPreview[]
  poll               Poll?
  bookmarks          MessageBookmark[]

  @@index([channelId, createdAt])
  @@index([channelId, pinned])
  @@index([directConversationId, createdAt])
  @@index([threadParentId])
  @@map("messages")
}

model Poll {
  id          String       @id @default(uuid())
  messageId   String       @unique @map("message_id")
  question    String
  multiSelect Boolean      @default(false) @map("multi_select")
  expiresAt   DateTime?    @map("expires_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  message Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  options PollOption[]
  @@map("polls")
}

model PollOption {
  id       String @id @default(uuid())
  pollId   String @map("poll_id")
  label    String
  position Int    @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]
  @@map("poll_options")
}

model PollVote {
  optionId String @map("option_id")
  userId   String @map("user_id")

  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([optionId, userId])
  @@map("poll_votes")
}

model Attachment {
  id        String         @id @default(uuid())
  messageId String?        @map("message_id")
  uploaderId String?       @map("uploader_id")
  filename  String
  url       String
  type      AttachmentType
  mimeType  String         @map("mime_type")
  sizeBytes Int            @map("size_bytes")
  width     Int?
  height    Int?
  thumbnailUrl String?     @map("thumbnail_url")
  createdAt DateTime       @default(now()) @map("created_at")

  message Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("attachments")
}

enum AttachmentType {
  image
  video
  gif
  file
}

model Reaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String
  isCustom  Boolean  @default(false) @map("is_custom")
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("reactions")
}

model CustomEmoji {
  id           String   @id @default(uuid())
  serverId     String   @map("server_id")
  name         String
  imageUrl     String   @map("image_url")
  uploadedById String?  @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  server     Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  uploadedBy User?  @relation("UploadedEmojis", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@unique([serverId, name])
  @@map("custom_emojis")
}

model Invite {
  id          String    @id @default(uuid())
  serverId    String    @map("server_id")
  createdById String?   @map("created_by_id")
  code        String    @unique
  maxUses     Int?      @map("max_uses")
  useCount    Int       @default(0) @map("use_count")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  server    Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  createdBy User?  @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([serverId])
  @@map("invites")
}

model Webhook {
  id          String   @id @default(uuid())
  channelId   String   @map("channel_id")
  name        String
  avatarUrl   String?  @map("avatar_url")
  token       String   @unique
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  messages  Message[]

  @@index([channelId])
  @@map("webhooks")
}

model LinkPreview {
  id          String   @id @default(uuid())
  messageId   String   @map("message_id")
  url         String
  title       String?
  description String?
  imageUrl    String?  @map("image_url")
  siteName    String?  @map("site_name")
  createdAt   DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("link_previews")
}

model ChannelNotifPref {
  userId    String         @map("user_id")
  channelId String         @map("channel_id")
  level     NotifLevel     @default(all)

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
  @@index([channelId])
  @@map("channel_notif_prefs")
}

enum NotifLevel {
  all
  mentions
  none
}

model RegistrationInvite {
  id        String    @id @default(uuid())
  code      String    @unique
  email     String
  serverId  String?   @map("server_id")
  used      Boolean   @default(false)
  usedAt    DateTime? @map("used_at")
  usedById  String?   @map("used_by_id")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  server Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)
  usedBy User?   @relation("UsedInvites", fields: [usedById], references: [id], onDelete: SetNull)

  @@map("registration_invites")
}

model ChannelReadState {
  userId       String   @map("user_id")
  channelId    String   @map("channel_id")
  lastReadAt   DateTime @map("last_read_at")
  mentionCount Int      @default(0) @map("mention_count")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
  @@map("channel_read_states")
}

model DmReadState {
  userId         String   @map("user_id")
  conversationId String   @map("conversation_id")
  lastReadAt     DateTime @map("last_read_at")
  mentionCount   Int      @default(0) @map("mention_count")

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([userId, conversationId])
  @@map("dm_read_states")
}

model StorageAudit {
  id              String    @id @default(uuid())
  status          String    @default("pending")
  totalSizeBytes  BigInt    @map("total_size_bytes")
  limitBytes      BigInt    @map("limit_bytes")
  orphanedCount   Int       @map("orphaned_count")
  orphanedBytes   BigInt    @map("orphaned_bytes")
  attachmentCount Int       @map("attachment_count")
  attachmentBytes BigInt    @map("attachment_bytes")
  messageCount    Int       @map("message_count")
  messageBytes    BigInt    @map("message_bytes")
  diskOrphanCount Int       @map("disk_orphan_count")
  diskOrphanBytes BigInt    @map("disk_orphan_bytes")
  totalFreeable   BigInt    @map("total_freeable")
  executedAt      DateTime? @map("executed_at")
  freedBytes      BigInt?   @map("freed_bytes")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("storage_audits")
}

model UserVolumeSetting {
  listenerId   String @map("listener_id")
  targetUserId String @map("target_user_id")
  volume       Int    @default(100)

  @@id([listenerId, targetUserId])
  @@map("user_volume_settings")
}

model AuditLog {
  id        String   @id @default(uuid())
  serverId  String   @map("server_id")
  actorId   String   @map("actor_id")
  action    String
  targetType String? @map("target_type")
  targetId   String? @map("target_id")
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  actor  User   @relation("auditLogActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt])
  @@map("audit_logs")
}

model ServerEvent {
  id             String            @id @default(uuid())
  serverId       String            @map("server_id")
  creatorId      String            @map("creator_id")
  name           String
  description    String?
  locationType   EventLocationType @map("location_type")
  channelId      String?           @map("channel_id")
  locationText   String?           @map("location_text")
  startAt        DateTime          @map("start_at")
  endAt          DateTime?         @map("end_at")
  status         EventStatus       @default(scheduled)
  recurrenceRule RecurrenceRule?   @map("recurrence_rule")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  server    Server          @relation(fields: [serverId], references: [id], onDelete: Cascade)
  creator   User            @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  channel   Channel?        @relation(fields: [channelId], references: [id], onDelete: SetNull)
  interests EventInterest[]

  @@index([serverId, startAt])
  @@index([serverId, status])
  @@map("server_events")
}

model EventInterest {
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  event ServerEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@map("event_interests")
}

enum EventLocationType {
  voice_channel
  custom
}

enum EventStatus {
  scheduled
  active
  completed
  cancelled
}

enum RecurrenceRule {
  daily
  weekly
  biweekly
  monthly
}

enum FriendshipStatus {
  pending
  accepted
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String           @map("requester_id")
  addresseeId String           @map("addressee_id")
  status      FriendshipStatus @default(pending)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  requester User @relation("FriendRequestsSent", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendRequestsReceived", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@map("friendships")
}

enum AutoModType {
  word_filter
  link_filter
  spam_detection
}

model MessageBookmark {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  messageId String   @map("message_id")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([userId, createdAt])
  @@map("message_bookmarks")
}

model AutoModRule {
  id        String      @id @default(uuid())
  serverId  String      @map("server_id")
  type      AutoModType
  enabled   Boolean     @default(true)
  config    Json        @default("{}")
  createdAt DateTime    @default(now()) @map("created_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  @@unique([serverId, type])
  @@map("automod_rules")
}
