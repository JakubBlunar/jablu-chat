# Prefer letting the repo generate this file:
#   pnpm local:sync-env
# (copies DATABASE_URL from `.env`, same password, host `postgres` → `127.0.0.1`.)
#
# Or copy this file to `.env.development` and edit the password to match your Postgres volume.

DATABASE_URL=postgresql://chat:changeme@127.0.0.1:5432/chat
REDIS_URL=redis://127.0.0.1:6379
SMTP_HOST=127.0.0.1
